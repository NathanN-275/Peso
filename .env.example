EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend URL options:
# 1. Complete override. Use this when you already know the exact API URL.
# EXPO_PUBLIC_BACKEND_URL=http://10.0.0.221:8000

# 2. Platform-aware local development.
# auto | ios-simulator | android-emulator | physical-device | production
EXPO_PUBLIC_BACKEND_TARGET=auto
EXPO_PUBLIC_BACKEND_PORT=8000
EXPO_PUBLIC_WEB_BACKEND_HOST=localhost
EXPO_PUBLIC_DEV_MACHINE_HOST=10.0.0.221
EXPO_PUBLIC_PRODUCTION_BACKEND_URL=https://api.example.com
